# .env.example — safe to commit. Copy to .env and fill in.   cp .env.example .env
# Your real .env is git-ignored (see .gitignore) — never commit secrets.

# App
PORT=3000
RAILS_ENV=development
RACK_ENV=development

# Secrets — LOCAL DEV defaults shown. Generate strong values for staging/prod.
POSTGRES_PASSWORD=postgres

# Service connection strings (host names match docker-compose)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/app
REDIS_URL=redis://redis:6379
